{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flagdeck.metasploit.input/1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "project_id": { "type": "string", "format": "uuid" },
    "scope_id": { "type": "string", "format": "uuid" },
    "module_type": {
      "enum": ["exploit", "auxiliary", "post", "payload", "encoder", "nop", "evasion"]
    },
    "fullname": { "type": "string", "minLength": 1, "maxLength": 512 },
    "options": {
      "type": "object",
      "maxProperties": 256,
      "propertyNames": { "pattern": "^[A-Za-z0-9_]{1,128}$" }
    },
    "confirmation": { "type": "string", "maxLength": 600 }
  }
}
